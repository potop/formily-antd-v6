{
  "name": "root",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/potop/formily-antd-v6.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "formily-tpl build",
    "build:docs": "NODE_OPTIONS=--openssl-legacy-provider dumi build",
    "lint": "eslint .",
    "release": "lerna publish from-package --yes",
    "start": "NODE_OPTIONS=--openssl-legacy-provider dumi dev",
    "test": "jest --coverage",
    "test:prod": "jest --coverage --silent",
    "preversion": "yarn install --ignore-engines && npm run build && npm run lint",
    "version:alpha": "lerna version prerelease --preid alpha",
    "version:beta": "lerna version prerelease --preid beta",
    "version:major": "lerna version major",
    "version:minor": "lerna version minor",
    "version:patch": "lerna version patch",
    "version:preminor": "lerna version preminor --preid beta",
    "version:rc": "lerna version prerelease --preid rc"
  },
  "lint-staged": {
    "*.{ts,tsx,js}": [
      "eslint",
      "pretty-quick --staged",
      "git add"
    ],
    "*.md": [
      "pretty-quick --staged",
      "git add"
    ]
  },
  "config": {
    "ghooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint --edit"
    }
  },
  "resolutions": {
    "rollup-plugin-typescript2": "^0.34.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.3.0",
    "@commitlint/config-conventional": "^17.3.0",
    "@commitlint/prompt-cli": "^17.3.0",
    "@formily/template": "^1.0.0-alpha.21",
    "@testing-library/jest-dom": "^5.0.0",
    "@types/fs-extra": "^9.0.13",
    "@types/jest": "^24.0.18",
    "@types/node": "^18.11.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.0",
    "@eslint/js": "^9.0.0",
    "@eslint/markdown": "^6.0.0",
    "antd": "^6.3.1",
    "cross-env": "^7.0.3",
    "dumi": "^1.1.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "typescript-eslint": "^8.0.0",
    "fs-extra": "^10.1.0",
    "ghooks": "^2.0.4",
    "glob": "^8.0.3",
    "jest": "^26.0.0",
    "jest-codemods": "^0.19.1",
    "jest-dom": "^3.1.2",
    "jest-localstorage-mock": "^2.3.0",
    "jest-styled-components": "6.3.3",
    "jest-watch-lerna-packages": "^1.1.0",
    "lerna": "^6.0.0",
    "lint-staged": "^13.0.4",
    "mfetch": "^0.2.27",
    "moment": "^2.29.4",
    "prettier": "^2.2.1",
    "pretty-format": "^29.3.1",
    "pretty-quick": "^3.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^3.0.0",
    "staged-git-files": "^1.1.2",
    "ts-jest": "^26.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.0"
  }
}
